# AI Test Platform - Backend Environment Variables
# 复制此文件为 .env 并填入实际值

# ======== 应用 ========
APP_ENV=dev
SECRET_KEY=change-me-in-production-use-random-string

# ======== 数据库 ========
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_test_platform
DB_USER=postgres
DB_PASSWORD=postgres

# ======== LLM 提供商 ========
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_STRONG=gpt-4o
OPENAI_MODEL_MEDIUM=gpt-4o-mini

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_STRONG=claude-3-5-sonnet-20241022

# 通义千问
QWEN_API_KEY=
QWEN_MODEL_STRONG=qwen-max

# ======== Qdrant (向量库，可选) ========
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ======== Redis (可选，Phase 2 使用) ========
REDIS_URL=redis://localhost:6379/0
